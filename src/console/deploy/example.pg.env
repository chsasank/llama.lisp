# Copy this file to `.pg.env` and update values according to your environment

# PostgreSQL Configuration
POSTGRES_PASSWORD=YOUR_POSTGRES_PASSWORD            # Password for PostgreSQL database
POSTGRES_DB=YOUR_POSTGRES_DATABASE_NAME             # PostgreSQL database name
POSTGRES_USER=YOUR POSTGRES_USERNAME                # PostgreSQL username

# HyperDX Logs Configuration
LOGS_BASE_URL=http://YOUR_HYPERDX_HOST:8080         # Base URL where HyperDX UI is accessible
LOGS_SOURCE_ID=YOUR_LOG_SOURCE_ID                   # Log source ID generated in HyperDX URL

# ETL Service Configuration
ETL_API_HOST=http://YOUR_ETL_HOST:8134              # Host and port where ETL API service is running
OTEL_EXPORTER_ENDPOINT=http://YOUR_OTEL_ENDPOINT:34318/v1/logs   # OTEL endpoint used to export logs

# HyperDX Browser Logging
HYPERDX_BROWSER_API_KEY=YOUR_BROWSER_API_KEY        # Ingestion API Key generated from HyperDX UI
HYPERDX_OTEL_URL=http://YOUR_HYPERDX_HOST:34318     # OTEL ingestion endpoint used by HyperDX